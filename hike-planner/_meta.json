{
  "name": "Hike Planner",
  "ownerId": "kn73h0b3vxspe7143ad7dk07xn822pwv",
  "slug": "hike-planner",
  "version": "2.0.0",
  "description": "v2.0.0: 轨迹地图 HTML 生成器 + 高德 GPS 坐标渲染 + 自动地图生成",
  "keywords": [
    "hiking",
    "trip",
    "travel",
    "planner",
    "route",
    "transportation",
    "map"
  ],
  "permissions": {
    "filesystem": {
      "scope": "configurable_output_dir",
      "operations": [
        "read",
        "write"
      ],
      "description": "在用户指定的 outputDir 下读写行程状态文件和行程计划 README.md"
    },
    "network": {
      "domains": [
        "restapi.amap.com",
        "wikipedia.org",
        "2bulu.com",
        "xiaohongshu.com",
        "bilibili.com",
        "youtube.com"
      ],
      "description": "查询高德地图 API（地理编码/路线规划）、Wikipedia、两步路、小红书、B站/YouTube"
    },
    "environment": {
      "variables": [
        "AMAP_WEBSERVICE_KEY"
      ],
      "description": "读取高德地图 API Key"
    },
    "execution": {
      "commands": [
        "curl",
        "python3",
        "node"
      ],
      "description": "执行地理编码脚本和路线渲染"
    }
  }
}