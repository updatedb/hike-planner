{
  "name": "Hike Planner",
  "ownerId": "kn73h0b3vxspe7143ad7dk07xn822pwv",
  "slug": "hike-planner",
  "version": "3.0.0",
  "description": "v3.0.0: 三文件职责统一 + 死代码清理 + 域名对齐 + SOP重命名 + 删除render-itinerary-map.sh + 地理编码4策略",
  "keywords": [
    "hiking",
    "trip",
    "travel",
    "planner",
    "route",
    "transportation",
    "map"
  ],
  "permissions": {
    "filesystem": {
      "scope": "configurable_output_dir",
      "operations": [
        "read",
        "write"
      ],
      "description": "在用户指定的 outputDir 下读写行程状态文件和行程计划文件"
    },
    "network": {
      "domains": [
        "restapi.amap.com",
        "is.autonavi.com",
        "a.amap.com",
        "wikipedia.org",
        "2bulu.com",
        "xiaohongshu.com",
        "bilibili.com",
        "unpkg.com"
      ],
      "description": "高德 API/瓦片/分享链接、Wikipedia、两步路、小红书、B站、Leaflet CDN"
    },
    "environment": {
      "variables": [
        "AMAP_WEBSERVICE_KEY"
      ],
      "description": "读取高德地图 API Key"
    },
    "execution": {
      "commands": [
        "curl",
        "python3",
        "node"
      ],
      "description": "执行地理编码脚本和路线渲染"
    }
  }
}