{
  "name": "Hike Planner",
  "ownerId": "kn73h0b3vxspe7143ad7dk07xn822pwv",
  "slug": "hike-planner",
  "version": "1.5.0",
  "description": "v1.5.0: 统一命名规则 - 目录名 destination-slug-YYYY-MM, 文件名从实际标题提取",
  "keywords": [
    "hiking",
    "trip",
    "travel",
    "planner",
    "route",
    "transportation",
    "map"
  ],
  "permissions": {
    "filesystem": {
      "scope": "configurable_output_dir",
      "operations": [
        "read",
        "write"
      ],
      "description": "在用户指定的 outputDir 下读写行程状态文件和行程计划 README.md"
    },
    "network": {
      "domains": [
        "restapi.amap.com",
        "wikipedia.org",
        "2bulu.com",
        "xiaohongshu.com",
        "bilibili.com",
        "youtube.com"
      ],
      "description": "查询高德地图 API（地理编码/路线规划）、Wikipedia、两步路、小红书、B站/YouTube"
    },
    "environment": {
      "variables": [
        "AMAP_WEBSERVICE_KEY",
        "HIKE_PLANNER_OUTPUT_DIR"
      ],
      "description": "读取高德地图 API Key 和输出目录配置"
    },
    "execution": {
      "commands": [
        "curl",
        "python3",
        "node"
      ],
      "description": "执行地理编码脚本和路线渲染"
    }
  }
}
